# Copy this file to .streamlit/secrets.toml (gitignored — never commit the
# real one) for local development against Postgres, or paste its contents
# into Streamlit Cloud's app Settings -> Secrets when deploying.
#
# Without this file/secret configured, the app falls back to local SQLite
# (sis_uoe.db) automatically — fine for local dev, NOT fine for Streamlit
# Cloud, where the filesystem is ephemeral and SQLite data is lost on
# every restart/redeploy.

DATABASE_URL = "postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
